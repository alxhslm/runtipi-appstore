{
  "name": "Time Machine NAS",
  "id": "timemachine-nas",
  "available": true,
  "short_desc": "Apple Time Machine compatible Samba NAS server",
  "author": "mbentley",
  "port": 4445,
  "no_gui": true,
  "categories": ["utilities", "network"],
  "description": "A macOS Time Machine backup destination using modern Samba (4.22) with built-in Avahi/Bonjour for automatic network discovery.",
  "tipi_version": 16,
  "version": "1.1.0",
  "updated_at": 1711224000000,
  "source": "https://github.com/mbentley/docker-timemachine",
  "exposable": false,
  "supported_architectures": ["arm64", "amd64"],
  "dynamic_config": true,
  "form_fields": [
    {
      "env_variable": "TM_USERNAME",
      "type": "text",
      "label": "Samba Username",
      "default": "tipi"
    },
    {
      "env_variable": "TM_PASSWORD",
      "type": "password",
      "label": "Samba Password",
      "default": "tipimachine"
    },
    {
      "env_variable": "TIMEMACHINE_PATH",
      "type": "text",
      "label": "Time Machine Host Path",
      "default": "/mnt/data_fast/timemachine"
    },
    {
      "env_variable": "TM_UID",
      "type": "number",
      "label": "Owner UID",
      "default": 1001
    },
    {
      "env_variable": "TM_GID",
      "type": "number",
      "label": "Owner GID",
      "default": 1001
    }
  ]
}
