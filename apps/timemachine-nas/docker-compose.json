{
  "schemaVersion": 2,
  "services": [
    {
      "name": "samba",
      "image": "servercontainers/samba",
      "isMain": true,
      "internalPort": "445",
      "networkMode": "host",
      "environment": [
        { "key": "AVAHI", "value": "false" },
        { "key": "WSDD2", "value": "false" },
        { "key": "SAMBA_CONF_LOG_LEVEL", "value": "1" },
        { "key": "SAMBA_CONF_WORKGROUP", "value": "MYGROUP" },
        { "key": "ACCOUNT_${SAMBA_USER:-tipi}", "value": "${SAMBA_PASS:-runtipi}" },
        { "key": "SAMBA_VOLUME_CONFIG_TM", "value": "[TimeMachine];path=/data;read only=no;fruit:time machine=yes;vfs objects=catia fruit streams_xattr;force user=${SAMBA_USER:-tipi}" },
        { "key": "SAMBA_VOLUME_CONFIG_ARC", "value": "[Archive];path=/shares/${ADDITIONAL_SHARE_NAME:-Archive};read only=no;vfs objects=catia fruit streams_xattr;force user=${SAMBA_USER:-tipi}" },
        { "key": "SAMBA_CONF_GLOBAL_vfs_objects", "value": "catia fruit streams_xattr" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_aapl", "value": "yes" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_model", "value": "MacSamba" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_metadata", "value": "stream" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_nfs_aces", "value": "no" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_copyfile", "value": "yes" }
      ],
      "volumes": [
        {
          "hostPath": "${TIMEMACHINE_PATH:-${APP_DATA_DIR}/data}",
          "containerPath": "/data"
        },
        {
          "hostPath": "${ADDITIONAL_SHARE_PATH:-/mnt/data/archive}",
          "containerPath": "/shares/${ADDITIONAL_SHARE_NAME:-Archive}"
        }
      ]
    }
  ]
}
