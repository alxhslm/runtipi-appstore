{
  "schemaVersion": 2,
  "services": [
    {
      "name": "vscode-server",
      "image": "codercom/code-server:4.95.3",
      "isMain": true,
      "internalPort": "8080",
      "environment": [
        { "key": "PUID", "value": "1000" },
        { "key": "PGID", "value": "1000" },
        { "key": "TZ", "value": "Etc/UTC" },
        { "key": "PASSWORD", "value": "password" }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/config",
          "containerPath": "/config",
          "type": "bind"
        }
      ]
    }
  ]
}
