{
  "name": "Time Machine NAS",
  "id": "timemachine-nas",
  "available": true,
  "short_desc": "Apple Time Machine compatible Samba NAS server",
  "author": "mbentley",
  "port": 4445,
  "no_gui": true,
  "categories": ["utilities", "network"],
  "description": "A macOS Time Machine backup destination and file server using modern Samba (4.22) with built-in Avahi/Bonjour for automatic network discovery. Optionally enable an extra file share via the toggle below.",
  "tipi_version": 21,
  "version": "1.4.0",
  "updated_at": 1711224000000,
  "source": "https://github.com/mbentley/docker-timemachine",
  "exposable": false,
  "supported_architectures": ["arm64", "amd64"],
  "dynamic_config": true,
  "form_fields": [
    {
      "env_variable": "TM_USERNAME",
      "type": "text",
      "label": "Samba Username",
      "default": "timemachine"
    },
    {
      "env_variable": "TM_PASSWORD",
      "type": "password",
      "label": "Samba Password",
      "default": "changeme"
    },
    {
      "env_variable": "TIMEMACHINE_PATH",
      "type": "text",
      "label": "Time Machine Host Path",
      "default": "/mnt/timemachine"
    },
    {
      "env_variable": "TM_UID",
      "type": "number",
      "label": "Owner UID",
      "default": 1000
    },
    {
      "env_variable": "TM_GID",
      "type": "number",
      "label": "Owner GID",
      "default": 1000
    },
    {
      "env_variable": "ENABLE_ADDITIONAL_SHARE",
      "type": "boolean",
      "label": "Enable Additional Share",
      "default": false
    },
    {
      "env_variable": "ADDITIONAL_SHARE_NAME",
      "type": "text",
      "label": "Additional Share Name",
      "default": "Share"
    },
    {
      "env_variable": "ADDITIONAL_SHARE_PATH",
      "type": "text",
      "label": "Additional Share Host Path",
      "default": "/tmp"
    }
  ]
}
