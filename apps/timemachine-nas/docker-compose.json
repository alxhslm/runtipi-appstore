{
  "schemaVersion": 2,
  "services": [
    {
      "name": "samba",
      "image": "dperson/samba",
      "isMain": true,
      "internalPort": "445",
      "networkMode": "host",
      "environment": [
        { "key": "TZ", "value": "Etc/UTC" },
        { "key": "USER", "value": "${SAMBA_USER:-tipi};${SAMBA_PASS:-runtipi}" },
        { "key": "SHARE", "value": "TimeMachine;/data;yes;no;no;${SAMBA_USER:-tipi};;" },
        { "key": "SHARE_1", "value": "${ADDITIONAL_SHARE_NAME:-Archive};/shares/Archive;yes;no;no;${SAMBA_USER:-tipi}" },
        { "key": "PERMISSIONS", "value": "true" },
        { "key": "GLOBAL_1", "value": "vfs objects = catia fruit streams_xattr" },
        { "key": "GLOBAL_2", "value": "fruit:time machine = yes" },
        { "key": "GLOBAL_3", "value": "fruit:aapl = yes" },
        { "key": "GLOBAL_4", "value": "fruit:metadata = netatalk" },
        { "key": "GLOBAL_5", "value": "fruit:model = MacSamba" },
        { "key": "GLOBAL_6", "value": "fruit:posix_rename = yes" },
        { "key": "GLOBAL_7", "value": "fruit:veto_appledouble = no" },
        { "key": "GLOBAL_8", "value": "fruit:wipe_intentionally_left_blank_rfork = yes" },
        { "key": "GLOBAL_9", "value": "fruit:delete_empty_adfiles = yes" },
        { "key": "GLOBAL_10", "value": "locking = no" },
        { "key": "GLOBAL_11", "value": "mangled names = no" },
        { "key": "GLOBAL_12", "value": "fruit:nfs_aces = no" },
        { "key": "GLOBAL_13", "value": "fruit:copyfile = yes" }
      ],
      "volumes": [
        {
          "hostPath": "${TIMEMACHINE_PATH:-${APP_DATA_DIR}/data}",
          "containerPath": "/data"
        },
        {
          "hostPath": "${ADDITIONAL_SHARE_PATH:-/mnt/data/archive}",
          "containerPath": "/shares/Archive"
        }
      ]
    }
  ]
}
