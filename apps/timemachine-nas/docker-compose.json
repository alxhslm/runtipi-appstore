{
  "schemaVersion": 2,
  "services": [
    {
      "name": "samba",
      "image": "dperson/samba",
      "isMain": true,
      "internalPort": "445",
      "networkMode": "host",
      "command": "-t -u \"${SAMBA_USER};${SAMBA_PASS}\" -s \"TimeMachine;/data;yes;no;no;${SAMBA_USER};;\" -p",
      "environment": [
        { "key": "TZ", "value": "Etc/UTC" }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        }
      ]
    }
  ]
}
