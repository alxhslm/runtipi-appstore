{
  "schemaVersion": 2,
  "services": [
    {
      "name": "samba",
      "image": "crazymax/samba:latest",
      "isMain": true,
      "internalPort": "445",
      "networkMode": "host",
      "environment": [
        { "key": "TZ", "value": "Etc/UTC" },
        { "key": "SAMBA_USER", "value": "${SAMBA_USER}" },
        { "key": "SAMBA_PASS", "value": "${SAMBA_PASS}" },
        { "key": "SAMBA_USERS", "value": "${SAMBA_USER}:${SAMBA_PASS}" },
        { "key": "SAMBA_VOLUME_CONFIG_TimeMachine", "value": "/data;Time Machine Backup;no;no;yes;${SAMBA_USER};yes;${SAMBA_USER};;;" },
        { "key": "SAMBA_GLOBAL_CONFIG_vfs_objects", "value": "fruit streams_xattr" },
        { "key": "SAMBA_GLOBAL_CONFIG_fruit_time_machine", "value": "yes" },
        { "key": "SAMBA_GLOBAL_CONFIG_fruit_aapl", "value": "yes" },
        { "key": "SAMBA_GLOBAL_CONFIG_state_directory", "value": "/tmp/samba/state" },
        { "key": "SAMBA_GLOBAL_CONFIG_cache_directory", "value": "/tmp/samba/cache" },
        { "key": "SAMBA_GLOBAL_CONFIG_lock_directory", "value": "/tmp/samba/lock" },
        { "key": "SAMBA_GLOBAL_CONFIG_pid_directory", "value": "/tmp/samba/pid" }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        }
      ]
    }
  ]
}
