{
  "schemaVersion": 2,
  "services": [
    {
      "name": "timemachine",
      "image": "mbentley/timemachine:smb",
      "isMain": true,
      "internalPort": "445",
      "networkMode": "host",
      "entrypoint": "/bin/sh -c 'if [ \"${ENABLE_ADDITIONAL_SHARE}\" = \"true\" ]; then export EXTRA_SHARES=\"${ADDITIONAL_SHARE_NAME}:/shares/additional\"; fi; exec /entrypoint.sh s6-svscan /etc/s6'",
      "environment": [
        { "key": "TM_USERNAME", "value": "${TM_USERNAME}" },
        { "key": "TM_GROUPNAME", "value": "${TM_USERNAME}" },
        { "key": "PASSWORD", "value": "${TM_PASSWORD}" },
        { "key": "TM_UID", "value": "${TM_UID}" },
        { "key": "TM_GID", "value": "${TM_GID}" },
        { "key": "SHARE_NAME", "value": "TimeMachine" },
        { "key": "SET_PERMISSIONS", "value": "true" },
        { "key": "ENABLE_ADDITIONAL_SHARE", "value": "${ENABLE_ADDITIONAL_SHARE}" },
        { "key": "ADDITIONAL_SHARE_NAME", "value": "${ADDITIONAL_SHARE_NAME}" }
      ],
      "volumes": [
        {
          "hostPath": "${TIMEMACHINE_PATH}",
          "containerPath": "/opt/${TM_USERNAME}"
        },
        {
          "hostPath": "${ADDITIONAL_SHARE_PATH}",
          "containerPath": "/shares/additional"
        }
      ]
    }
  ]
}
