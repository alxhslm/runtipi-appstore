{
  "schemaVersion": 2,
  "services": [
    {
      "name": "samba",
      "image": "ghcr.io/servercontainers/samba",
      "isMain": true,
      "internalPort": "445",
      "networkMode": "host",
      "environment": [
        { "key": "AVAHI", "value": "false" },
        { "key": "WSDD2", "value": "false" },
        { "key": "SAMBA_CONF_LOG_LEVEL", "value": "1" },
        { "key": "ACCOUNT_${SAMBA_USER:-tipi}", "value": "${SAMBA_PASS:-runtipi}" },
        { "key": "SAMBA_CONF_GLOBAL_force_user", "value": "${SAMBA_USER:-tipi}" },
        { "key": "SAMBA_CONF_GLOBAL_vfs_objects", "value": "catia fruit streams_xattr" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_aapl", "value": "yes" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_model", "value": "MacSamba" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_metadata", "value": "stream" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_nfs_aces", "value": "no" },
        { "key": "SAMBA_CONF_GLOBAL_fruit_copyfile", "value": "yes" },
        { "key": "SAMBA_VOLUME_CONFIG_TM", "value": "[TimeMachine];path=/data;valid users=${SAMBA_USER:-tipi};read only=no;fruit:time machine=yes" },
        { "key": "SAMBA_VOLUME_CONFIG_ARC", "value": "[${ADDITIONAL_SHARE_NAME:-Archive}];path=/shares/Archive;valid users=${SAMBA_USER:-tipi};read only=no" },
        { "key": "PUID", "value": "${PUID:-100}" },
        { "key": "PGID", "value": "${PGID:-101}" }
      ],
      "volumes": [
        {
          "hostPath": "${TIMEMACHINE_PATH:-/mnt/data_fast/timemachine}",
          "containerPath": "/data"
        },
        {
          "hostPath": "${ADDITIONAL_SHARE_PATH:-/mnt/storage_bulk/archive}",
          "containerPath": "/shares/Archive"
        }
      ]
    }
  ]
}
