{
  "schemaVersion": 2,
  "services": [
    {
      "name": "samba",
      "image": "dperson/samba",
      "isMain": true,
      "internalPort": "445",
      "networkMode": "host",
      "environment": [
        { "key": "TZ", "value": "Etc/UTC" },
        { "key": "USER", "value": "${SAMBA_USER};${SAMBA_PASS}" },
        { "key": "SHARE", "value": "TimeMachine;/data;yes;no;no;${SAMBA_USER};;" },
        { "key": "SHARE_1", "value": "${ADDITIONAL_SHARE_NAME};/shares/${ADDITIONAL_SHARE_NAME};yes;no;no;${SAMBA_USER}" },
        { "key": "GLOBAL_1", "value": "vfs objects = fruit streams_xattr" },
        { "key": "GLOBAL_2", "value": "fruit:time machine = yes" },
        { "key": "GLOBAL_3", "value": "fruit:aapl = yes" },
        { "key": "GLOBAL_4", "value": "fruit:metadata = stream" },
        { "key": "GLOBAL_5", "value": "fruit:model = MacSamba" },
        { "key": "GLOBAL_6", "value": "fruit:posix_rename = yes" },
        { "key": "GLOBAL_7", "value": "fruit:veto_appledouble = no" },
        { "key": "GLOBAL_8", "value": "fruit:wipe_intentionally_left_blank_rfork = yes" },
        { "key": "GLOBAL_9", "value": "fruit:delete_empty_adfiles = yes" }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/data"
        },
        {
          "hostPath": "${ADDITIONAL_SHARE_PATH}",
          "containerPath": "/shares/${ADDITIONAL_SHARE_NAME}"
        }
      ]
    }
  ]
}
