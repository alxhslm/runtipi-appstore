{
  "name": "Time Machine NAS",
  "id": "timemachine-nas",
  "available": true,
  "short_desc": "Apple Time Machine compatible Samba NAS server",
  "author": "crazy-max",
  "port": 4445,
  "no_gui": true,
  "categories": ["utilities", "network"],
  "description": "Turn your RunTipi server into a Time Machine backup destination for your Mac. (Note: App will listen on port 445 on the host regardless of the port setting below).",
  "tipi_version": 14,
  "version": "0.3.3",
  "updated_at": 1711224000000,
  "source": "https://github.com/ServerContainers/samba",
  "exposable": false,
  "supported_architectures": ["arm64", "amd64"],
  "dynamic_config": true,
  "form_fields": [
    {
      "env_variable": "SAMBA_USER",
      "type": "text",
      "label": "Username",
      "default": "tipi"
    },
    {
      "env_variable": "SAMBA_PASS",
      "type": "password",
      "label": "Password",
      "default": "tipimachine"
    },
    {
      "env_variable": "TIMEMACHINE_PATH",
      "type": "text",
      "label": "Time Machine Host Path",
      "default": "/mnt/data_fast/timemachine"
    },
    {
      "env_variable": "ADDITIONAL_SHARE_NAME",
      "type": "text",
      "label": "Additional SMB Share Name",
      "default": "Archive"
    },
    {
      "env_variable": "ADDITIONAL_SHARE_PATH",
      "type": "text",
      "label": "Additional SMB Share Host Path",
      "default": "/mnt/storage_bulk/archive"
    },
    {
      "env_variable": "PUID",
      "type": "number",
      "label": "Owner PUID",
      "default": 100
    },
    {
      "env_variable": "PGID",
      "type": "number",
      "label": "Owner PGID",
      "default": 101
    }
  ]
}